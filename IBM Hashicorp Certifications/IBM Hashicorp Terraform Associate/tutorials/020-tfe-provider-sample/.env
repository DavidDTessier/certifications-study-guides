# .env - NEVER COMMIT THIS FILE
# 
# Setup Instructions:
# 1. Get your HCP Terraform API token from: https://app.terraform.io/app/settings/tokens
# 2. Set the TFE_TOKEN environment variable with your token
# 3. Alternatively, copy terraform.tfvars.example to terraform.tfvars and set tfe_token there
#
# Example:
# export TFE_TOKEN="your-api-token-here"
#
# Terraform Cloud Token for provider:
TFE_TOKEN="<REPLACE_ME>"
TF_TOKEN_app_terraform_io="<REPLACE_ME>"